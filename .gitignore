# Root Git Ignore for backend and frontend

# Node modules
node_modules/
backend/node_modules/
frontend/node_modules/

# Build outputs
dist/
out/
backend/dist/
frontend/.next/
frontend/out/

# Env files
.env
.env.*
backend/.env
frontend/.env

# Logs and temp
logs/
*.log
coverage/
.tmp/

# OS/editor noise
.DS_Store
Thumbs.db

# Misc
npm-debug.log*
yarn-debug.log*
yarn-error.log*